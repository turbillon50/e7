# ──────────────────────────────────────────────────────────────
# E7 Pictures — environment variables (placeholders only)
# Copy to `.env.local` and fill in real values. Never commit secrets.
# ──────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=https://e7-pictures.vercel.app

# ── Authentication · Clerk ────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/participate

# ── Database · Neon (PostgreSQL) ──────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/e7?sslmode=require

# ── Email · Resend ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hola@e7pictures.mx

# ── Payments · Mercado Pago ───────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxx

# ── Payments · Stripe (optional / international) ───────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── File uploads (optional · UploadThing / S3) ────────────────
UPLOADTHING_TOKEN=
